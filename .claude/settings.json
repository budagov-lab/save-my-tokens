{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/smt_agent_hook.py"
          }
        ]
      },
      {
        "matcher": "advisor",
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/smt_agent_hook.py"
          }
        ]
      },
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/smt_agent_hook.py"
          }
        ]
      },
      {
        "matcher": "Grep",
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/smt_agent_hook.py"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/smt_agent_hook.py"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Skill",
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/smt_agent_hook.py"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/smt_agent_hook.py"
          }
        ]
      }
    ]
  },
  "permissions": {
    "defaultMode": "auto",
    "allow": [
      "Read",
      "Edit(src/**)",
      "Edit(tests/**)",
      "Edit(.claude/**)",
      "Write(src/**)",
      "Write(tests/**)",
      "Bash"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(git reset --hard:*)",
      "Bash(git push --force:*)"
    ],
    "ask": [
      "Write(README.md)",
      "Write(CLAUDE.md)"
    ]
  },
  "env": {
    "PYTHONPATH": "src",
    "NEO4J_LOG_LEVEL": "info",
    "SMT_AGENT": "1"
  },
  "respectGitignore": true
}
