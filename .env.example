# Neo4j Configuration
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# Neo4j Memory (tune with: smt config set SMT_NEO4J_HEAP_MAX 1g)
# Low:  256m / 512m / 256m  (default, works on 4GB Docker Desktop)
# Med:  512m / 1g   / 512m  (recommended for large codebases)
# High: 1g   / 2g   / 1g    (needs 6GB+ Docker Desktop memory)
SMT_NEO4J_HEAP_INIT=256m
SMT_NEO4J_HEAP_MAX=512m
SMT_NEO4J_PAGECACHE=256m

# Embedding Model (local, no API key required)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true
API_WORKERS=1

# Logging
LOG_LEVEL=INFO

# Environment
DEBUG=true
