# Neo4j Configuration
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# OpenAI Configuration (optional, for semantic search)
OPENAI_API_KEY=your-api-key-here

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true
API_WORKERS=1

# Logging
LOG_LEVEL=INFO

# Environment
DEBUG=true
